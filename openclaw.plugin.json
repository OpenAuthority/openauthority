{
  "id": "openauthority",
  "name": "open-authority",
  "displayName": "Open Authority",
  "version": "1.0.0",
  "description": "Authorization policy engine for Open Authority — semantic authorization, action normalization, audit logging, and HITL approval",
  "author": "Firma-AI",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "apiVersion": "1",
    "type": "plugin",
    "capabilities": [
      "semantic-authorization",
      "action-normalization",
      "audit-logging",
      "hitl-approval"
    ],
    "hooks": [
      "before_tool_call"
    ],
    "installPath": "~/.openclaw/plugins/openauthority"
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "bundlePath": {
        "type": "string",
        "description": "Path to the active bundle directory",
        "default": "data/bundles/active"
      },
      "proposalPath": {
        "type": "string",
        "description": "Path to the bundle proposals directory",
        "default": "data/bundles/proposals"
      },
      "auditLogFile": {
        "type": "string",
        "description": "Path to the JSONL audit log file",
        "default": "data/audit.jsonl"
      },
      "cee": {
        "type": "object",
        "description": "Contextual Enforcement Engine configuration",
        "properties": {
          "trustedDomains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Domains considered trusted for action classification",
            "default": []
          },
          "protectedPaths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "File-system paths protected from agent access",
            "default": []
          }
        },
        "additionalProperties": false
      },
      "hitl": {
        "type": "object",
        "description": "Human-in-the-Loop approval configuration",
        "properties": {
          "telegram": {
            "type": "object",
            "description": "Telegram approval channel configuration",
            "properties": {
              "botToken": {
                "type": "string",
                "description": "Telegram Bot API token",
                "default": ""
              },
              "chatId": {
                "type": "string",
                "description": "Telegram chat or group ID",
                "default": ""
              }
            },
            "additionalProperties": false
          },
          "slack": {
            "type": "object",
            "description": "Slack approval channel configuration",
            "properties": {
              "botToken": {
                "type": "string",
                "description": "Slack Bot User OAuth Token (xoxb-...)",
                "default": ""
              },
              "channelId": {
                "type": "string",
                "description": "Slack channel ID (not name)",
                "default": ""
              },
              "signingSecret": {
                "type": "string",
                "description": "Slack Signing Secret for webhook verification",
                "default": ""
              },
              "interactionPort": {
                "type": "number",
                "description": "Port for the Slack webhook interaction server",
                "default": 3201
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  },
  "keywords": [
    "openclaw",
    "policy",
    "authorization",
    "semantic-authorization",
    "action-normalization",
    "hitl",
    "audit"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Firma-AI/openauthority"
  }
}
