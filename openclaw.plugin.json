{
  "id": "openauthority",
  "name": "openauthority",
  "displayName": "Open Authority",
  "version": "1.0.0",
  "description": "Authorization policy engine for Open Authority — evaluate ABAC/RBAC policies with audit logging",
  "author": "Firma-AI",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "apiVersion": "1",
    "type": "plugin",
    "capabilities": [
      "policy-evaluation",
      "audit-logging",
      "tool-restriction",
      "prompt-protection",
      "model-restriction"
    ],
    "hooks": [
      "before_tool_call",
      "before_prompt_build",
      "before_model_resolve"
    ],
    "installPath": "~/.openclaw/plugins/openauthority",
    "configSchema": {
      "type": "object",
      "properties": {
        "rulesFile": {
          "type": "string",
          "description": "Path to the JSON rules file",
          "default": "data/rules.json"
        },
        "auditLogFile": {
          "type": "string",
          "description": "Path to the JSONL audit log file",
          "default": "data/audit.jsonl"
        },
        "uiPort": {
          "type": "number",
          "description": "Port for the policy engine UI server",
          "default": 7331
        },
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable the policy engine",
          "default": true
        }
      },
      "additionalProperties": false
    }
  },
  "keywords": [
    "openclaw",
    "policy",
    "authorization",
    "abac",
    "rbac",
    "audit"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Firma-AI/openauthority"
  }
}
