{
  "name": "@clawthority/clawthority",
  "version": "1.3.0",
  "description": "Authorization policy engine plugin for Clawthority",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "scripts/post-install.mjs"
  ],
  "scripts": {
    "plugin:install": "node scripts/post-install.mjs",
    "postinstall": "node scripts/post-install.mjs",
    "prepare": "node scripts/sync-version.mjs",
    "prebuild": "npm run build --workspace=packages/action-registry && node scripts/sync-version.mjs && node scripts/gen-build-info.mjs",
    "build": "tsc",
    "sync-version": "node scripts/sync-version.mjs",
    "gen-build-info": "node scripts/gen-build-info.mjs",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "pretest": "npm run build --workspace=packages/action-registry && node scripts/gen-build-info.mjs",
    "test": "vitest run",
    "pretest:coverage": "npm run build --workspace=packages/action-registry && node scripts/gen-build-info.mjs",
    "test:coverage": "vitest run --coverage",
    "pretest:e2e": "npm run build --workspace=packages/action-registry && node scripts/gen-build-info.mjs",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "pretest:e2e:coverage": "npm run build --workspace=packages/action-registry && node scripts/gen-build-info.mjs",
    "test:e2e:coverage": "vitest run --config vitest.e2e.config.ts --coverage",
    "pretest:dod": "npm run build --workspace=packages/action-registry && node scripts/gen-build-info.mjs",
    "test:dod": "vitest run --config vitest.dod.config.ts",
    "pretest:watch": "npm run build --workspace=packages/action-registry && node scripts/gen-build-info.mjs",
    "test:watch": "vitest",
    "prevalidate:spec": "npm run build --workspace=packages/action-registry && node scripts/gen-build-info.mjs && tsc",
    "validate:spec": "node scripts/validate-spec-alignment.mjs",
    "validate:manifests": "node scripts/validate-skill-manifests.mjs",
    "list-auto-permits": "node scripts/auto-permits.mjs list",
    "show-auto-permit": "node scripts/auto-permits.mjs show",
    "validate-auto-permits": "node scripts/auto-permits.mjs validate",
    "test-auto-permit": "node scripts/auto-permits.mjs test",
    "remove-auto-permit": "node scripts/auto-permits.mjs remove",
    "revoke-auto-permit": "node scripts/auto-permits.mjs revoke",
    "ci": "npm run test:coverage && npm run test:e2e:coverage && npm run validate:spec && npm run validate:manifests"
  },
  "dependencies": {
    "@openclaw/action-registry": "*",
    "@sinclair/typebox": "^0.34.0",
    "cheerio": "^1.2.0",
    "chokidar": "^4.0.0",
    "express": "^4.21.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.13",
      "minGatewayVersion": "2026.3.13"
    },
    "build": {
      "openclawVersion": "2026.3.13",
      "pluginSdkVersion": "2026.3.13"
    }
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenAuthority/clawthority"
  }
}
