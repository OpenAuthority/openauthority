{
  "name": "@openauthority/openauthority",
  "version": "0.1.1",
  "description": "Authorization policy engine plugin for Open Authority",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "prebuild": "node scripts/sync-version.mjs",
    "build": "tsc",
    "sync-version": "node scripts/sync-version.mjs",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:coverage": "vitest run --config vitest.e2e.config.ts --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cedar-policy/cedar-wasm": "^4.0.0",
    "@sinclair/typebox": "^0.34.0",
    "chokidar": "^4.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenAuthority/openauthority"
  }
}
