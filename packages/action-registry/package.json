{
  "name": "@openclaw/action-registry",
  "version": "1.0.1",
  "description": "Shared action class registry for OpenClaw / Clawthority",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
